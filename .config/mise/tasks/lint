#!/usr/bin/env bash
#MISE description="Run all linters across workspace modules"
#MISE sources=["**/*.go", ".config/golangci.yml", "go.work"]
set -euo pipefail

root=$(pwd)
failed=0
while IFS= read -r mod; do
    echo "==> $mod"
    if ! (cd "$root/$mod" && golangci-lint run -c "$root/.config/golangci.yml"); then
        echo "FAIL lint: $mod"
        failed=1
    fi
done < <(sed -n '/^use/,/^)/p' go.work | grep -E '^\t\.' | tr -d '\t')

dprint check -c .config/dprint.json
exit $failed
